{
  "templates": {
    "react-component": {
      "description": "Create a new React component with TypeScript",
      "template": [
        "import { cn } from '@/lib/utils';",
        "",
        "interface {{componentName}}Props {",
        "  children?: React.ReactNode;",
        "  className?: string;",
        "}",
        "",
        "/**",
        " * {{componentName}} component",
        " */",
        "export function {{componentName}}({ children, className, ...props }: {{componentName}}Props) {",
        "  return (",
        "    <div className={cn('', className)} {...props}>",
        "      {children}",
        "    </div>",
        "  );",
        "}",
        "",
        "export default {{componentName}};"
      ]
    },
    "nestjs-controller": {
      "description": "Create a new NestJS controller with proper decorators",
      "template": [
        "import {",
        "  Controller,",
        "  Get,",
        "  Post,",
        "  Body,",
        "  Param,",
        "  Delete,",
        "  Put,",
        "  UseGuards,",
        "  HttpStatus,",
        "  HttpException,",
        "} from '@nestjs/common';",
        "import { ApiTags, ApiOperation, ApiResponse } from '@nestjs/swagger';",
        "import { {{serviceName}}Service } from './{{serviceName}}.service';",
        "import { Create{{entityName}}Dto } from './dto/create-{{entityName}}.dto';",
        "import { Update{{entityName}}Dto } from './dto/update-{{entityName}}.dto';",
        "import { JwtAuthGuard } from '../auth/guards/jwt-auth.guard';",
        "",
        "@ApiTags('{{entityName}}')",
        "@Controller('{{entityName}}')",
        "export class {{entityName}}Controller {",
        "  constructor(private readonly {{serviceName}}Service: {{serviceName}}Service) {}",
        "",
        "  @Post()",
        "  @UseGuards(JwtAuthGuard)",
        "  @ApiOperation({ summary: 'Create {{entityName}}' })",
        "  @ApiResponse({ status: 201, description: '{{entityName}} created successfully' })",
        "  async create(@Body() create{{entityName}}Dto: Create{{entityName}}Dto) {",
        "    try {",
        "      const result = await this.{{serviceName}}Service.create(create{{entityName}}Dto);",
        "      return { success: true, data: result };",
        "    } catch (error) {",
        "      throw new HttpException(",
        "        'Failed to create {{entityName}}',",
        "        HttpStatus.INTERNAL_SERVER_ERROR",
        "      );",
        "    }",
        "  }",
        "",
        "  @Get()",
        "  @UseGuards(JwtAuthGuard)",
        "  @ApiOperation({ summary: 'Get all {{entityName}}' })",
        "  @ApiResponse({ status: 200, description: '{{entityName}} retrieved successfully' })",
        "  async findAll() {",
        "    return this.{{serviceName}}Service.findAll();",
        "  }",
        "",
        "  @Get(':id')",
        "  @UseGuards(JwtAuthGuard)",
        "  @ApiOperation({ summary: 'Get {{entityName}} by ID' })",
        "  @ApiResponse({ status: 200, description: '{{entityName}} retrieved successfully' })",
        "  async findOne(@Param('id') id: string) {",
        "    return this.{{serviceName}}Service.findOne(id);",
        "  }",
        "",
        "  @Put(':id')",
        "  @UseGuards(JwtAuthGuard)",
        "  @ApiOperation({ summary: 'Update {{entityName}}' })",
        "  @ApiResponse({ status: 200, description: '{{entityName}} updated successfully' })",
        "  async update(",
        "    @Param('id') id: string,",
        "    @Body() update{{entityName}}Dto: Update{{entityName}}Dto,",
        "  ) {",
        "    return this.{{serviceName}}Service.update(id, update{{entityName}}Dto);",
        "  }",
        "",
        "  @Delete(':id')",
        "  @UseGuards(JwtAuthGuard)",
        "  @ApiOperation({ summary: 'Delete {{entityName}}' })",
        "  @ApiResponse({ status: 200, description: '{{entityName}} deleted successfully' })",
        "  async remove(@Param('id') id: string) {",
        "    return this.{{serviceName}}Service.remove(id);",
        "  }",
        "}"
      ]
    },
    "nestjs-service": {
      "description": "Create a new NestJS service with proper error handling",
      "template": [
        "import { Injectable, Logger, HttpException, HttpStatus } from '@nestjs/common';",
        "import { PrismaService } from '../prisma/prisma.service';",
        "import { Create{{entityName}}Dto } from './dto/create-{{entityName}}.dto';",
        "import { Update{{entityName}}Dto } from './dto/update-{{entityName}}.dto';",
        "",
        "@Injectable()",
        "export class {{entityName}}Service {",
        "  private readonly logger = new Logger({{entityName}}Service.name);",
        "",
        "  constructor(private readonly prisma: PrismaService) {}",
        "",
        "  async create(create{{entityName}}Dto: Create{{entityName}}Dto) {",
        "    try {",
        "      const result = await this.prisma.{{modelName}}.create({",
        "        data: create{{entityName}}Dto,",
        "      });",
        "",
        "      this.logger.log(`{{entityName}} created: ${result.id}`);",
        "      return result;",
        "    } catch (error) {",
        "      this.logger.error('Failed to create {{entityName}}', error);",
        "      throw new HttpException(",
        "        'Failed to create {{entityName}}',",
        "        HttpStatus.INTERNAL_SERVER_ERROR",
        "      );",
        "    }",
        "  }",
        "",
        "  async findAll() {",
        "    try {",
        "      return await this.prisma.{{modelName}}.findMany();",
        "    } catch (error) {",
        "      this.logger.error('Failed to fetch {{entityName}}', error);",
        "      throw new HttpException(",
        "        'Failed to fetch {{entityName}}',",
        "        HttpStatus.INTERNAL_SERVER_ERROR",
        "      );",
        "    }",
        "  }",
        "",
        "  async findOne(id: string) {",
        "    try {",
        "      const result = await this.prisma.{{modelName}}.findUnique({",
        "        where: { id },",
        "      });",
        "",
        "      if (!result) {",
        "        throw new HttpException(",
        "          '{{entityName}} not found',",
        "          HttpStatus.NOT_FOUND",
        "        );",
        "      }",
        "",
        "      return result;",
        "    } catch (error) {",
        "      this.logger.error(`Failed to find {{entityName}} by ID: ${id}`, error);",
        "      throw error;",
        "    }",
        "  }",
        "",
        "  async update(id: string, update{{entityName}}Dto: Update{{entityName}}Dto) {",
        "    try {",
        "      const result = await this.prisma.{{modelName}}.update({",
        "        where: { id },",
        "        data: update{{entityName}}Dto,",
        "      });",
        "",
        "      this.logger.log(`{{entityName}} updated: ${id}`);",
        "      return result;",
        "    } catch (error) {",
        "      this.logger.error(`Failed to update {{entityName}}: ${id}`, error);",
        "      throw new HttpException(",
        "        'Failed to update {{entityName}}',",
        "        HttpStatus.INTERNAL_SERVER_ERROR",
        "      );",
        "    }",
        "  }",
        "",
        "  async remove(id: string) {",
        "    try {",
        "      const result = await this.prisma.{{modelName}}.delete({",
        "        where: { id },",
        "      });",
        "",
        "      this.logger.log(`{{entityName}} deleted: ${id}`);",
        "      return result;",
        "    } catch (error) {",
        "      this.logger.error(`Failed to delete {{entityName}}: ${id}`, error);",
        "      throw new HttpException(",
        "        'Failed to delete {{entityName}}',",
        "        HttpStatus.INTERNAL_SERVER_ERROR",
        "      );",
        "    }",
        "  }",
        "}"
      ]
    },
    "nestjs-module": {
      "description": "Create a new NestJS module",
      "template": [
        "import { Module } from '@nestjs/common';",
        "import { {{entityName}}Controller } from './{{entityName}}.controller';",
        "import { {{entityName}}Service } from './{{entityName}}.service';",
        "import { PrismaModule } from '../prisma/prisma.module';",
        "",
        "@Module({",
        "  imports: [PrismaModule],",
        "  controllers: [{{entityName}}Controller],",
        "  providers: [{{entityName}}Service],",
        "  exports: [{{entityName}}Service],",
        "})",
        "export class {{entityName}}Module {}"
      ]
    },
    "nestjs-dto": {
      "description": "Create a new NestJS DTO with validation",
      "template": [
        "import { IsString, IsEmail, IsOptional, IsNumber, IsBoolean } from 'class-validator';",
        "import { ApiProperty } from '@nestjs/swagger';",
        "",
        "export class Create{{entityName}}Dto {",
        "  @IsString()",
        "  @ApiProperty({ description: '{{entityName}} name' })",
        "  name: string;",
        "",
        "  @IsEmail()",
        "  @ApiProperty({ description: '{{entityName}} email' })",
        "  email: string;",
        "",
        "  @IsOptional()",
        "  @IsString()",
        "  @ApiProperty({ description: '{{entityName}} description', required: false })",
        "  description?: string;",
        "}",
        "",
        "export class Update{{entityName}}Dto {",
        "  @IsOptional()",
        "  @IsString()",
        "  @ApiProperty({ description: '{{entityName}} name', required: false })",
        "  name?: string;",
        "",
        "  @IsOptional()",
        "  @IsEmail()",
        "  @ApiProperty({ description: '{{entityName}} email', required: false })",
        "  email?: string;",
        "",
        "  @IsOptional()",
        "  @IsString()",
        "  @ApiProperty({ description: '{{entityName}} description', required: false })",
        "  description?: string;",
        "}"
      ]
    },
