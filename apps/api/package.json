{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "NODE_OPTIONS=--max-old-space-size=8192 nest build",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "nest start",
    "dev": "nest start --watch",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "start:tcp": "node dist/tcp-main",
    "dev:tcp": "nest start --watch --entryFile tcp-main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "clean": "rm -rf dist",
    "db:seed": "ts-node prisma/seed.ts",
    "db:push": "prisma generate --schema=./prisma/schema.prisma && prisma db push --schema=./prisma/schema.prisma",
    "postinstall": "prisma generate --schema=./prisma/schema.prisma"
  },
  "dependencies": {
    "@adminjs/express": "^6.1.1",
    "@adminjs/nestjs": "^6.1.0",
    "@adminjs/prisma": "^5.0.4",
    "@aws-sdk/client-s3": "^3.840.0",
    "@gleandroj/shared": "*",
    "@modelcontextprotocol/sdk": "^1.22.0",
    "@nestjs-modules/ioredis": "^2.0.2",
    "@nestjs/axios": "^4.0.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/platform-socket.io": "^11.1.3",
    "@nestjs/schedule": "^6.0.1",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/websockets": "^11.1.3",
    "@prisma/client": "^6.10.0",
    "@react-email/components": "^0.0.41",
    "@react-email/render": "^1.1.2",
    "@react-email/tailwind": "^1.0.5",
    "@sentry/node": "^10.35.0",
    "@sentry/profiling-node": "^10.35.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@tailwindcss/typography": "^0.5.16",
    "@tiptap/extension-horizontal-rule": "2.1.13",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/nodemailer": "^6.4.17",
    "@types/redis": "^4.0.11",
    "adminjs": "^7.8.17",
    "axios": "^1.9.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "latest",
    "body-parser": "^2.2.0",
    "bullmq": "^5.65.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "crypto": "^1.0.1",
    "csv-parse": "^6.1.0",
    "cuid": "^3.0.0",
    "date-fns-tz": "^3.2.0",
    "express-formidable": "^1.2.0",
    "express-session": "^1.18.2",
    "googleapis": "^144.0.0",
    "ical-generator": "^10.0.0",
    "ioredis": "^5.7.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.1",
    "multer-s3": "^3.0.1",
    "nodemailer": "^7.0.3",
    "openai": "^5.3.0",
    "otplib": "^12.0.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "prisma": "^6.10.0",
    "qrcode": "^1.5.4",
    "react": "^19",
    "react-dom": "^19",
    "redis": "^5.8.2",
    "reflect-metadata": "^0.1.13",
    "retell-sdk": "^4.66.0",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "swagger-ui-express": "^5.0.1",
    "tailwindcss": "^3.4.17",
    "twilio": "^5.3.5",
    "uuid": "^11.1.0",
    "zod": "^3.25.51",
    "zod-to-json-schema": "^3.25.0"
  },
  "devDependencies": {
    "@babel/plugin-syntax-import-assertions": "^7.27.1",
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/bcrypt": "^5.0.2",
    "@types/body-parser": "^1.19.6",
    "@types/express": "^4.17.22",
    "@types/jest": "^29.5.2",
    "@types/multer": "^2.0.0",
    "@types/node": "^22",
    "@types/passport-jwt": "^4.0.1",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19",
    "@types/supertest": "^2.0.12",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts", "tsx"],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)sx?$": "ts-jest"
    },
    "collectCoverageFrom": ["**/*.(t|j)s(x)?"],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    },
    "preset": "ts-jest",
    "testPathIgnorePatterns": ["/node_modules/"],
    "setupFilesAfterEnv": ["<rootDir>/../jest-setup.ts"]
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
