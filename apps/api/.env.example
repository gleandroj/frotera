# ─────────────────────────────────────────────────────────────────────────────
# Frotera API – HTTP / WebSocket server (main.ts)
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
APP_NAME=Frotera
# Set to "true" to block all API requests (maintenance mode)
SERVICE_SUSPENDED=false

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/frotera

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT Secrets (use strong random strings in production) ────────────────────
JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me
JWT_VERIFICATION_SECRET=change-me
JWT_PASSWORD_RESET_SECRET=change-me

# ── Encryption ───────────────────────────────────────────────────────────────
ENCRYPTION_KEY=change-me-32-chars-hex-key

# ── SMTP / Email ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM="Frotera" <noreply@example.com>

# ── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# ── AWS S3 ───────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_S3_BUCKET=frotera-uploads
# Leave blank to use AWS default endpoint; set for MinIO or other S3-compatible
AWS_S3_ENDPOINT=
AWS_S3_FORCE_PATH_STYLE=false

# ── BullMQ (Redis queue cleanup) ─────────────────────────────────────────────
# Age in seconds to retain completed jobs (0 = remove immediately)
BULLMQ_REMOVE_ON_COMPLETE_AGE=3600
BULLMQ_REMOVE_ON_COMPLETE_COUNT=1000
# Age in seconds to retain failed jobs
BULLMQ_REMOVE_ON_FAIL_AGE=86400
# BULLMQ_REMOVE_ON_FAIL_COUNT=

# ── Sentry (optional) ────────────────────────────────────────────────────────
SENTRY_DSN=
