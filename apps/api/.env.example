# Application Configuration
NODE_ENV=development
PORT=3001
APP_NAME=Rotera
# App Domain (used for admin user email: admin@APP_DOMAIN)
APP_DOMAIN=rsfrotas.radisa.com.br
# Admin Password (optional - defaults to "admin123" if not set)
ADMIN_PASSWORD=

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rsfrotas
# Prisma Configuration (Optional - for development)
PRISMA_GENERATE_DATAPROXY=true

# JWT Secrets (Generate strong random strings)
JWT_SECRET=your-jwt-secret-key-here
JWT_REFRESH_SECRET=your-jwt-refresh-secret-key-here
JWT_VERIFICATION_SECRET=your-jwt-verification-secret-key-here


#Encryption
ENCRYPTION_KEY=

# Email Configuration (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM="Rotera" <noreply@example.com>
CONTACT_EMAIL=contact@example.com

# Frontend URLs
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# CORS Configuration (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:3000

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here

# AWS S3 Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_S3_BUCKET=your-s3-bucket-name
AWS_S3_ENDPOINT=
AWS_S3_FORCE_PATH_STYLE=false

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Tracker TCP (GT06 only; devices must be pre-registered)
TRACKER_TCP_PORT=5023
# Optional: append every raw TCP recv chunk as hex (tab-separated: time, remote, length, hex)
# TRACKER_TCP_HEX_DEBUG_FILE=/tmp/tracker-tcp-hex.log

# To run the tracker TCP process separately: pnpm run start:tracker (uses tracker-main.ts)
TRACKER_REDIS_STREAM_KEY=tracker:positions
TRACKER_REDIS_LAST_PREFIX=tracker:last:

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

TWILIO_ADDRESS_SID=
TWILIO_BUNDLE_SID=

# Google (OAuth + optional Maps for tracker route test script)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional: for scripts/test-tracker-tcp.js route simulation (Routes API — enable in Google Cloud Console)
# GOOGLE_MAPS_API_KEY=

# BullMQ Configuration (Redis Queue Cleanup)
# Age in seconds to keep completed jobs (default: 3600 = 1 hour)
# Set to 0 to remove immediately after completion
BULLMQ_REMOVE_ON_COMPLETE_AGE=3600

# Maximum number of completed jobs to keep (default: 1000)
BULLMQ_REMOVE_ON_COMPLETE_COUNT=1000

# Age in seconds to keep failed jobs (default: 86400 = 24 hours)
# Set to 0 to remove immediately after failure
BULLMQ_REMOVE_ON_FAIL_AGE=86400

# Maximum number of failed jobs to keep (optional, default: unlimited)
# BULLMQ_REMOVE_ON_FAIL_COUNT=

# Sentry Configuration
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
