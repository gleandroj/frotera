generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String?
  phoneNumber   String?
  language      String?   @default("pt") // User's preferred language for emails and communications
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  emailVerified DateTime?

  // 2FA fields
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?

  // Admin access
  isSuperAdmin Boolean @default(false)
  isSystemUser Boolean @default(false)

  // Force password change on next login (e.g. temp passwords)
  mustChangePassword Boolean @default(false)

  // Relations
  memberships OrganizationMember[]

  @@map("users")
}

model VerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@map("verification_tokens")
}

model Organization {
  id          String  @id @default(cuid())
  name        String
  description String?
  currency    String  @default("USD") // Currency code (USD, BRL, etc.)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  memberships         OrganizationMember[]
  notifications       Notification[]
  vehicles            Vehicle[]
  trackerDevices      TrackerDevice[]
  customers           Customer[]
  customerFleetSettings CustomerFleetSetting[]
  roles               Role[]
  drivers             Driver[]
  documents           VehicleDocument[]
  fuelLogs            FuelLog[]
  checklistTemplates  ChecklistTemplate[]
  checklistEntries    ChecklistEntry[]
  incidents           Incident[]
  telemetryAlerts     TelemetryAlert[]
  geofenceZones       GeofenceZone[]

  @@map("organizations")
}

model Customer {
  id             String    @id @default(cuid())
  organizationId String
  parentId       String?
  name           String
  inactive       Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent         Customer?      @relation("CustomerHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children       Customer[]     @relation("CustomerHierarchy")
  vehicles       Vehicle[]
  memberAccess        OrganizationMemberCustomer[]
  drivers             Driver[]
  fleetSettings       CustomerFleetSetting[]
  geofenceZones       GeofenceZone[]
  incidents           Incident[]
  checklistTemplates  ChecklistTemplate[]

  @@index([organizationId])
  @@index([parentId])
  @@index([organizationId, inactive])
  @@map("customers")
}

/// Telemetria / frota por empresa (Customer). Valores efetivos podem herdar do pai na árvore na leitura.
model CustomerFleetSetting {
  id                            String   @id @default(cuid())
  organizationId                String
  customerId                    String
  deviceOfflineThresholdMinutes Int?
  defaultSpeedLimitKmh          Float?
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([organizationId, customerId])
  @@index([organizationId])
  @@map("customer_fleet_settings")
}

enum TrackerModel {
  X12_GT06
}

enum AlertType {
  SPEEDING
  HARSH_BRAKING
  RAPID_ACCELERATION
  GEOFENCE_ENTER
  GEOFENCE_EXIT
  DEVICE_OFFLINE
  LOW_BATTERY
  IGNITION_ON
  IGNITION_OFF
  SOS
  POWER_CUT
  SHOCK

  @@map("alert_type")
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL

  @@map("alert_severity")
}

enum GeofenceType {
  CIRCLE
  POLYGON

  @@map("geofence_type")
}

model Vehicle {
  id               String         @id @default(cuid())
  organizationId   String
  name             String?        // Make/model e.g. FIAT/PALIO FIRE
  plate            String?
  serial           String?        // Serial e.g. SUN511533819
  color            String?
  year             String?        // Year e.g. 2015
  renavam          String?
  chassis          String?
  vehicleType      String?        // Tipo de veículo (texto livre — legado)
  /// Espécie (finalidade): códigos em @gleandroj/shared (ex.: PASSENGER_AUTOMOBILE)
  vehicleSpecies      String?
  /// Tipo de carroceria (passeio): códigos em @gleandroj/shared (ex.: BODY_SUV)
  vehicleBodyType     String?
  /// Tração / propulsão: códigos em @gleandroj/shared (ex.: TRACTION_AUTOMOTOR)
  vehicleTraction     String?
  /// Categoria de uso: códigos em @gleandroj/shared (ex.: USE_PRIVATE)
  vehicleUseCategory  String?
  inactive         Boolean        @default(false)
  /// km/h; null = sem monitoramento de velocidade (alertas SPEEDING)
  speedLimit       Float?
  /// Hodômetro (km) na entrada do veículo na frota; usado no 1º abastecimento quando não há log anterior
  initialOdometerKm Float?
  notes            String?        // Informações / histórico
  trackerDeviceId  String?        @unique
  customerId       String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  trackerDevice  TrackerDevice? @relation(fields: [trackerDeviceId], references: [id], onDelete: SetNull)
  customer       Customer       @relation(fields: [customerId], references: [id], onDelete: Restrict)
  driverAssignments DriverVehicleAssignment[]
  documents         VehicleDocument[]
  fuelLogs          FuelLog[]
  checklistEntries  ChecklistEntry[]
  incidents         Incident[]
  telemetryAlerts   TelemetryAlert[]
  memberAssignments OrganizationMemberVehicle[]

  @@index([organizationId])
  @@index([customerId])
  @@map("vehicles")
}

model TrackerDevice {
  id                  String        @id @default(cuid())
  organizationId      String
  imei                String        @unique
  model               TrackerModel
  name                String?
  serialSat           String?       // Serial satélite
  equipmentModel      String?       // Modelo equipamento e.g. SUNT CH
  individualPassword  String?       // Senha individual
  carrier             String?       // Operadora (Dados CHIP)
  simCardNumber       String?       // SimCard
  cellNumber          String?       // N. Cel.
  /** Set when device connects to TCP server; null when disconnected. */
  connectedAt         DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  organization  Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vehicle       Vehicle?
  positions     DevicePosition[]
  statusLogs    DeviceStatusLog[]
  telemetryAlerts TelemetryAlert[]

  @@index([organizationId])
  @@index([imei])
  @@map("tracker_devices")
}

/// IMEI seen on TCP login before a TrackerDevice exists (superadmin onboarding).
model TrackerDiscoveryLogin {
  id                String   @id @default(cuid())
  imei              String   @unique
  protocol          String?
  firstSeenAt       DateTime @default(now())
  lastSeenAt        DateTime
  loginCount        Int      @default(1)
  lastRemoteAddress String?

  @@index([lastSeenAt])
  @@map("tracker_discovery_logins")
}

model DevicePosition {
  id          String   @id @default(cuid())
  deviceId    String
  latitude    Float
  longitude   Float
  altitude    Float?
  speed       Float?
  heading     Float?
  recordedAt  DateTime
  createdAt   DateTime @default(now())
  // GT06 status fields
  ignitionOn  Boolean?
  voltageLevel Int?
  gsmSignal   Int?
  alarmCode   Int?
  chargeOn    Boolean?
  powerCut    Boolean?
  lbsMcc      Int?
  lbsMnc      Int?
  lbsLac      Int?
  lbsCellId   Int?

  device TrackerDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, recordedAt])
  @@map("device_positions")
}

model DeviceStatusLog {
  id           String   @id @default(cuid())
  deviceId     String
  recordedAt   DateTime @default(now())
  ignitionOn   Boolean?
  voltageLevel Int?
  gsmSignal    Int?
  alarmCode    Int?
  chargeOn     Boolean?
  powerCut     Boolean?

  device TrackerDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, recordedAt])
  @@map("device_status_logs")
}

model TelemetryAlert {
  id               String         @id @default(cuid())
  organizationId   String
  vehicleId        String?
  deviceId         String
  type             AlertType
  severity         AlertSeverity
  message          String
  metadata         Json?
  acknowledgedAt   DateTime?
  acknowledgedBy   String?
  createdAt        DateTime       @default(now())

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vehicle      Vehicle?            @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  device       TrackerDevice       @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  acknowledger OrganizationMember? @relation("AlertAcknowledger", fields: [acknowledgedBy], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([vehicleId])
  @@index([deviceId])
  @@index([type])
  @@index([createdAt])
  @@index([acknowledgedAt])
  @@map("telemetry_alerts")
}

model GeofenceZone {
  id             String       @id @default(cuid())
  organizationId String
  customerId     String
  name           String
  description    String?
  type           GeofenceType
  coordinates    Json
  vehicleIds     String[]
  alertOnEnter   Boolean      @default(true)
  alertOnExit    Boolean      @default(true)
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([customerId])
  @@index([active])
  @@map("geofence_zones")
}

model OrganizationMember {
  id                 String   @id @default(cuid())
  roleId             String
  userId             String
  organizationId     String
  active             Boolean  @default(true)
  customerRestricted Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [roleId], references: [id])
  customers         OrganizationMemberCustomer[]
  createdDocuments  VehicleDocument[]
  fuelLogs          FuelLog[]
  checklistEntries  ChecklistEntry[]
  createdIncidents  Incident[] @relation("IncidentCreatedBy")
  acknowledgedAlerts TelemetryAlert[] @relation("AlertAcknowledger")
  vehicles OrganizationMemberVehicle[]
  drivers  OrganizationMemberDriver[]

  @@unique([userId, organizationId])
  @@map("organizationMembers")
}

model OrganizationMemberCustomer {
  id                 String @id @default(cuid())
  organizationMemberId String
  customerId         String

  organizationMember OrganizationMember @relation(fields: [organizationMemberId], references: [id], onDelete: Cascade)
  customer            Customer            @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([organizationMemberId, customerId])
  @@map("organizationMemberCustomers")
}

model OrganizationMemberVehicle {
  id                   String @id @default(cuid())
  organizationMemberId String
  vehicleId            String

  organizationMember OrganizationMember @relation(fields: [organizationMemberId], references: [id], onDelete: Cascade)
  vehicle            Vehicle            @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([organizationMemberId, vehicleId])
  @@map("organizationMemberVehicles")
}

model OrganizationMemberDriver {
  id                   String @id @default(cuid())
  organizationMemberId String
  driverId             String

  organizationMember OrganizationMember @relation(fields: [organizationMemberId], references: [id], onDelete: Cascade)
  driver             Driver             @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@unique([organizationMemberId, driverId])
  @@map("organizationMemberDrivers")
}

enum IncidentType {
  ACCIDENT
  THEFT
  FINE
  BREAKDOWN
  VANDALISM
  OTHER
}

enum IncidentStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RoleModule {
  VEHICLES
  TRACKING
  TRACKER_DISCOVERIES
  COMPANIES
  USERS
  REPORTS
  DRIVERS
  DOCUMENTS
  FUEL
  CHECKLIST
  INCIDENTS
  TELEMETRY
  FINANCIAL
  DASHBOARD
  REPORTS_FUEL_CONSUMPTION
  REPORTS_FUEL_COSTS
  REPORTS_FUEL_BENCHMARK
  REPORTS_FUEL_EFFICIENCY
  REPORTS_FUEL_SUMMARY

  @@map("role_module")
}

enum RoleAction {
  VIEW
  CREATE
  EDIT
  DELETE

  @@map("role_action")
}

enum RoleScope {
  ALL
  ASSIGNED

  @@map("role_scope")
}

model Role {
  id             String   @id @default(cuid())
  organizationId String?
  key            String?  @unique
  name           String
  description    String?
  isSystem       Boolean  @default(false)
  color          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization?      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  permissions  RolePermission[]
  members      OrganizationMember[]

  @@index([organizationId])
  @@map("roles")
}

model RolePermission {
  id      String       @id @default(cuid())
  roleId  String
  module  RoleModule
  actions RoleAction[]
  scope   RoleScope    @default(ALL)

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, module])
  @@map("role_permissions")
}

enum NotificationType {
  // Add notification types as needed
  GENERAL
}

model Notification {
  id             String           @id @default(cuid())
  organizationId String
  type           NotificationType
  title          String
  message        String
  metadata       Json? // Additional context (e.g., amount, phone number, etc.)
  read           Boolean          @default(false)
  readAt         DateTime?
  emailSent      Boolean          @default(false)
  emailSentAt    DateTime?
  createdAt      DateTime         @default(now())

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([read])
  @@index([createdAt])
  @@index([type])
  @@map("notifications")
}

model Incident {
  id              String           @id @default(cuid())
  organizationId  String
  customerId      String
  vehicleId       String?
  driverId        String?
  createdById     String
  type            IncidentType
  title           String
  description     String?
  date            DateTime
  location        String?
  status          IncidentStatus   @default(OPEN)
  severity        IncidentSeverity @default(LOW)
  cost            Float?
  insuranceClaim  Boolean          @default(false)
  claimNumber     String?
  notes           String?
  resolvedAt      DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer              @relation(fields: [customerId], references: [id], onDelete: Restrict)
  vehicle      Vehicle?              @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  createdBy    OrganizationMember    @relation("IncidentCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  attachments  IncidentAttachment[]

  @@index([organizationId])
  @@index([customerId])
  @@index([vehicleId])
  @@index([driverId])
  @@index([status])
  @@index([type])
  @@index([date])
  @@map("incidents")
}

model IncidentAttachment {
  id         String   @id @default(cuid())
  incidentId String
  fileUrl    String
  fileType   String
  name       String
  createdAt  DateTime @default(now())

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId])
  @@map("incident_attachments")
}

// Single-row table: feature flags editable in AdminJS. Default keeps public signup disabled.
model AppSettings {
  id                            String   @id @default(cuid())
  signupEnabled                 Boolean  @default(false)
  signupCreateOrganizationEnabled Boolean @default(false)
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt

  @@map("app_settings")
}

model Driver {
  id             String    @id @default(cuid())
  organizationId String
  customerId     String
  name           String
  cpf            String?   // CPF — unique por organização (ver @@unique abaixo)
  cnh            String?   // Número da CNH
  cnhCategory    String?   // A, B, C, D, E
  cnhExpiry      DateTime? // Data de vencimento da CNH — para alertas futuros
  phone          String?
  email          String?
  photo          String?   // URL da foto — upload real em fase futura (S3/R2)
  active         Boolean   @default(true) // false = soft delete
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization       Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer           Customer                 @relation(fields: [customerId], references: [id], onDelete: Restrict)
  vehicleAssignments DriverVehicleAssignment[]
  fuelLogs           FuelLog[]
  memberAssignments OrganizationMemberDriver[]

  @@unique([organizationId, cpf]) // CPF único por organização (null não viola unique)
  @@index([organizationId])
  @@index([customerId])
  @@map("drivers")
}

model DriverVehicleAssignment {
  id        String    @id @default(cuid())
  driverId  String
  vehicleId String
  startDate DateTime  @default(now())
  endDate   DateTime? // null = vínculo ativo
  isPrimary Boolean   @default(false)
  createdAt DateTime  @default(now())

  driver  Driver  @relation(fields: [driverId], references: [id], onDelete: Cascade)
  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([driverId])
  @@index([vehicleId])
  @@map("driver_vehicle_assignments")
}

enum DocumentType {
  CRLV
  INSURANCE
  LICENSE
  INSPECTION
  OTHER

  @@map("document_type")
}

model VehicleDocument {
  id             String       @id @default(cuid())
  organizationId String
  vehicleId      String
  createdById    String       // OrganizationMember.id
  type           DocumentType
  title          String
  fileUrl        String?      // URL externa (placeholder — upload S3/R2 futuro)
  issueDate      DateTime?
  expiryDate     DateTime?    // null = sem vencimento
  notes          String?
  active         Boolean      @default(true) // soft delete
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vehicle      Vehicle            @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  createdBy    OrganizationMember @relation(fields: [createdById], references: [id])

  @@index([organizationId])
  @@index([vehicleId])
  @@index([expiryDate])
  @@map("vehicle_documents")
}

enum FuelType {
  GASOLINE
  ETHANOL
  DIESEL
  ELECTRIC
  GNV

  @@map("fuel_type")
}

model FuelLog {
  id             String    @id @default(cuid())
  organizationId String
  vehicleId      String
  driverId       String?   // FK para Driver (quando módulo Drivers existir)
  createdById    String    // FK para OrganizationMember.id

  date           DateTime
  odometer       Float     // km no momento do abastecimento
  liters         Float
  pricePerLiter  Float
  totalCost      Float     // CALCULADO: liters * pricePerLiter — NUNCA aceitar do cliente
  fuelType       FuelType

  station        String?   // nome do posto
  state          String?   // UF (ex.: RS, SP) — alinhado a municípios IBGE
  city           String?   // nome do município (IBGE)
  receipt        String?   // URL do comprovante no S3
  notes          String?

  // Campo calculado no momento da escrita (km/l vs abastecimento anterior do mesmo veículo)
  // null quando é o primeiro abastecimento do veículo ou odômetro anterior não disponível
  consumption    Float?    // km/l

  // Preço médio de mercado (estado da org) no momento do registro — snapshot
  marketPriceRef Float?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vehicle        Vehicle            @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  driver         Driver?            @relation(fields: [driverId], references: [id], onDelete: SetNull)
  createdBy      OrganizationMember @relation(fields: [createdById], references: [id])

  @@index([organizationId])
  @@index([vehicleId])
  @@index([driverId])
  @@index([organizationId, date])
  @@index([vehicleId, date])
  @@map("fuel_logs")
}

model FuelPriceSnapshot {
  id        String   @id @default(cuid())
  state     String
  fuelType  FuelType
  avgPrice  Float
  minPrice  Float?
  maxPrice  Float?
  source    String   @default("combustivelapi")
  refDate   DateTime
  fetchedAt DateTime @default(now())

  @@index([state, fuelType, refDate])
  @@index([fuelType, refDate])
  @@map("fuel_price_snapshots")
}

// Localidades IBGE — populadas via `pnpm db:seed` (arquivos em prisma/data/), sem chamada runtime à API do IBGE
model IbgeUf {
  sigla      String          @id
  nome       String
  municipios IbgeMunicipio[]

  @@map("ibge_ufs")
}

model IbgeMunicipio {
  id      Int    @id // código IBGE do município
  nome    String
  ufSigla String
  uf      IbgeUf @relation(fields: [ufSigla], references: [sigla], onDelete: Cascade)

  @@index([ufSigla, nome])
  @@map("ibge_municipios")
}

// ─── Checklist ────────────────────────────────────────────────────────────────

enum ItemType {
  YES_NO
  TEXT
  NUMBER
  PHOTO
  SELECT
  SIGNATURE
  FILE

  @@map("item_type")
}

enum EntryStatus {
  PENDING
  COMPLETED
  INCOMPLETE

  @@map("entry_status")
}

enum ChecklistDriverRequirement {
  REQUIRED
  OPTIONAL
  HIDDEN

  @@map("checklist_driver_requirement")
}

model ChecklistTemplate {
  id             String   @id @default(cuid())
  organizationId String
  customerId     String
  name           String
  description    String?
  active         Boolean  @default(true)
  /// Quando false, a entrada pode ser criada sem veículo.
  vehicleRequired Boolean @default(true)
  driverRequirement ChecklistDriverRequirement @default(OPTIONAL)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer               @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items        ChecklistTemplateItem[]
  entries      ChecklistEntry[]

  @@index([organizationId])
  @@index([customerId])
  @@map("checklist_templates")
}

model ChecklistTemplateItem {
  id         String   @id @default(cuid())
  templateId String
  order      Int
  label      String
  type       ItemType
  required   Boolean  @default(true)
  options    String[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  template ChecklistTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  answers  ChecklistAnswer[]

  @@index([templateId])
  @@map("checklist_template_items")
}

model ChecklistEntry {
  id             String      @id @default(cuid())
  organizationId String
  templateId     String
  vehicleId      String?
  driverId       String?
  memberId       String
  status         EntryStatus @default(PENDING)
  completedAt    DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  template     ChecklistTemplate  @relation(fields: [templateId], references: [id])
  vehicle      Vehicle?           @relation(fields: [vehicleId], references: [id])
  member       OrganizationMember @relation(fields: [memberId], references: [id])
  answers      ChecklistAnswer[]

  @@index([organizationId])
  @@index([templateId])
  @@index([vehicleId])
  @@index([memberId])
  @@index([status])
  @@map("checklist_entries")
}

model ChecklistAnswer {
  id           String   @id @default(cuid())
  entryId      String
  itemId       String?
  itemLabel    String?
  itemType     String?
  itemOptions  String[]
  itemRequired Boolean?
  itemOrder    Int?
  value        String?
  photoUrl     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  entry ChecklistEntry         @relation(fields: [entryId], references: [id], onDelete: Cascade)
  item  ChecklistTemplateItem? @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@unique([entryId, itemId])
  @@index([entryId])
  @@index([itemId])
  @@map("checklist_answers")
}
