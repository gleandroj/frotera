# ─────────────────────────────────────────────────────────────────────────────
# Frotera TCP Server – tracker process only (tcp-main.ts)
# Modules: ConfigModule, ScheduleModule, PrismaModule, TrackersTcpModule
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=production

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/frotera

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Tracker TCP ──────────────────────────────────────────────────────────────
# TCP port devices connect to (GT06 protocol)
TRACKER_TCP_PORT=5023
# Redis stream key where position packets are published
TRACKER_REDIS_STREAM_KEY=tracker:positions
# Redis key prefix for last-known position cache per device
TRACKER_REDIS_LAST_PREFIX=tracker:last:
# Optional: log every raw recv chunk as hex (tab-separated: time, remote, length, hex)
# TRACKER_TCP_HEX_DEBUG_FILE=/tmp/tracker-tcp-hex.log
